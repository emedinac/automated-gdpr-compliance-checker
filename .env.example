# LLM provider: "ollama" for local model lifecycle management, or "openai" for
# OpenAI and OpenAI-compatible chat APIs.
LLM_PROVIDER=ollama

# Ollama defaults.
# For Docker Compose, use http://ollama:11434.
# For local development without Docker, use http://localhost:11434.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# OpenAI-compatible API settings.
# Hosted OpenAI example:
#   LLM_PROVIDER=openai
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENAI_API_KEY=sk-...
#   OPENAI_MODEL=gpt-4o-mini
#
# Local Ollama OpenAI-compatible example:
#   LLM_PROVIDER=openai
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_API_KEY=ollama
#   OPENAI_MODEL=gemma3:4b
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
